{
  "name": "Audivo",
  "short_name": "Audivo",
  "description": "Offline-first PWA music player. Play, download, and organize your music library.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "minimal-ui", "standalone"],
  "orientation": "any",
  "background_color": "#0a0a0f",
  "theme_color": "#1db954",
  "categories": ["music", "entertainment", "utilities"],
  "lang": "en-US",
  "dir": "ltr",
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/icons/icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "related_applications": [],
  "shortcuts": [
    {
      "name": "Library",
      "short_name": "Library",
      "description": "View your music library",
      "url": "/library",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "192x192" }]
    },
    {
      "name": "Search",
      "short_name": "Search",
      "description": "Search your music",
      "url": "/search",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "192x192" }]
    },
    {
      "name": "Downloads",
      "short_name": "Downloads",
      "description": "Download from YouTube",
      "url": "/downloads",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "192x192" }]
    },
    {
      "name": "Favorites",
      "short_name": "Favorites",
      "description": "Your favorite songs",
      "url": "/favorites",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "192x192" }]
    }
  ],
  "screenshots": [],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "widgets": [
    {
      "name": "Now Playing",
      "description": "Shows currently playing song with controls",
      "tag": "now-playing-widget",
      "ms_ac_template": "widget/widget.json",
      "data": "/widget/data.json",
      "screenshots": [],
      "icons": [
        { "src": "/icons/icon.png", "sizes": "192x192", "type": "image/png" }
      ],
      "backgrounds": [
        { "src": "/icons/icon.png", "sizes": "192x192", "type": "image/png" }
      ],
      "display": "standalone",
      "orientation": "any",
      "screenshots": [],
      "launch": "/?widget=now-playing"
    }
  ]
}
